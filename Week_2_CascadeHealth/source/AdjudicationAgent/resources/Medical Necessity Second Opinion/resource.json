            "title": "claude-3-haiku-20240307"
          }
        ]
      },
      "prompt": {
        "type": "string",
        "title": "Prompt",
        "description": "You are providing a second medical-necessity opinion for a health insurance claim adjudication. Be concise and decisive.\n\nClaim details:\n- Procedures: {{cpt_codes_and_diagnoses}}\n- Provider narrative: {{provider_narrative}}\n- Total charges: {{total_charges}}\n\nInitial assessment from primary adjudicator (gpt-4o):\n{{initial_assessment}}\n\nProvide your independent medical-necessity assessment. For each procedure-diagnosis pairing, state whether it is medically necessary, not medically necessary, or uncertain, with a one-sentence justification. If you disagree with the primary adjudicator's assessment, explain why. End with a recommended disposition (APPROVE / DENY / REVIEW) and brief rationale."
      },
      "maxTokens": {
        "type": "integer",
        "title": "Max tokens",
        "description": "The maximum number of tokens to generate before stopping"
      },
      "systemPrompt": {
        "type": "string",
        "title": "System prompt",
        "description": "System prompt providing context and instructions to Claude",
        "enum": [
          "You are a helpful assistant."
        ]
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "description": "Amount of randomness injected into the response (0.0-1.0)",
        "enum": [
          0.3
        ]
      },
      "topP": {
        "type": "number",
        "title": "Top P",
        "description": "Use nucleus sampling"
      },
      "topK": {
        "type": "integer",
        "title": "Top K",
        "description": "Only sample from the top K options for each subsequent token"
      }
    },
