{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "/content/agent.json",
      "type": "agent",
      "uniqueId": "f92a8f1a-27d1-4862-b780-d20df9a760aa",
      "input": {
        "type": "object",
        "required": [
          "document_reference"
        ],
        "properties": {
          "document_reference": {
            "type": "string",
            "description": "Storage reference or path to the claim PDF.",
            "definitions": {
              "job-attachment": {
                "type": "object",
                "properties": {
                  "ID": {
                    "type": "string",
                    "description": "Orchestrator attachment key"
                  },
                  "FullName": {
                    "type": "string",
                    "description": "File name"
                  },
                  "MimeType": {
                    "type": "string",
                    "description": "The MIME type of the content, such as \"application/json\" or \"image/png\""
                  },
                  "Metadata": {
                    "type": "object",
                    "description": "Dictionary<string, string> of metadata",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "ID"
                ],
                "x-uipath-resource-kind": "JobAttachment"
              }
            }
          }
        },
        "title": "Inputs"
      },
      "output": {
        "type": "object",
        "required": [
          "claim_id",
          "member_id",
          "date_of_birth",
          "policy_number",
          "provider_npi",
          "provider_name",
          "total_charges",
          "provider_narrative",
          "service_lines",
          "confidence_score",
          "needs_fallback",
          "consistency_error"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "member_id": {
            "type": "string"
          },
          "date_of_birth": {
            "type": "string",
            "format": "date"
          },
          "policy_number": {
            "type": "string"
          },
          "provider_npi": {
            "type": "string"
          },
          "provider_name": {
            "type": "string"
          },
          "total_charges": {
            "type": "number"
          },
          "provider_narrative": {
            "type": "string"
          },
          "service_lines": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "date_of_service",
                "cpt_code",
                "icd10_code",
                "charges"
              ],
              "properties": {
                "date_of_service": {
                  "type": "string",
                  "format": "date"
                },
                "cpt_code": {
                  "type": "string"
                },
                "icd10_code": {
                  "type": "string"
                },
                "charges": {
                  "type": "number"
                }
              }
            }
          },
          "confidence_score": {
            "type": "number"
          },
          "needs_fallback": {
            "type": "boolean"
          },
          "consistency_error": {
            "type": "boolean"
          }
        }
      }
    }
  ]
}