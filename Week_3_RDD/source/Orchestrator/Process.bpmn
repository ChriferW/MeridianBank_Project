      <bpmn:incoming>edge_bzGJtv</bpmn:incoming>
      <bpmn:outgoing>edge_jBcOl7</bpmn:outgoing>
      <bpmn:script><![CDATA[const dt = vars.decisionEvent.risk_output.decision_type;

  let finalDisposition = "unknown";
  if (dt === "APPROVE" || dt === "auto_approve") {
    finalDisposition = "approved";
  } else if (dt === "DENY" || dt === "auto_decline") {
    finalDisposition = "declined";
  }

  return {
    ...vars.decisionEvent,
    final_disposition: finalDisposition
  };]]></bpmn:script>
    </bpmn:scriptTask>
