    <bpmn:scriptTask id="Activity_v5hZAa" name="Merge Human Decision" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse7" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error11" />
          <uipath:output name="decisionEvent" type="jsonSchema" source="" var="decisionEvent" custom="true" target=""><![CDATA[=vars.scriptResponse7]]></uipath:output>
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>edge_i048NJ</bpmn:incoming>
      <bpmn:outgoing>edge_JoY3Io</bpmn:outgoing>
      <bpmn:script><![CDATA[const reviewerAction = (vars.humanReviewerDecision || "").toLowerCase();
  const reviewerComment = vars.humanReviewerComment;
  const agentDecision = vars.decisionEvent.risk_output.decision_type;

  const reviewerApproved = reviewerAction === "approve";
  const reviewerRejected = reviewerAction === "reject";

  const finalDisposition = reviewerApproved ? "approved" : (reviewerRejected ? "declined" : "unknown");

  const agentApproved = ["auto_approve", "APPROVE"].includes(agentDecision);
  const agentDeclined = ["auto_decline", "DENY"].includes(agentDecision);
  const agentAbstained = !agentApproved && !agentDeclined;

  let was_override = false;
  if (agentApproved && reviewerRejected) was_override = true;
  if (agentDeclined && reviewerApproved) was_override = true;

  const humanTouchpoint = {
    reviewer_action: vars.humanReviewerDecision,
    reviewer_comment: reviewerComment,
    reviewed_at: new Date().toISOString(),
    agent_decision_at_review: agentDecision,
    was_override: was_override,
    agent_abstained: agentAbstained
  };

  return {
    ...vars.decisionEvent,
    human_touchpoints: [...(vars.decisionEvent.human_touchpoints || []), humanTouchpoint],
    final_disposition: finalDisposition
  };]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_uXriUo" name="Merge Compliance Response" scriptFormat="JavaScript">
      <bpmn:extensionElements>
