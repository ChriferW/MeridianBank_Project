      <bpmn:incoming>edge_6PrORn</bpmn:incoming>
      <bpmn:outgoing>edge_uEUlD7</bpmn:outgoing>
      <bpmn:script><![CDATA[const referenceNumber = vars.decisionEvent.decision_event_id || ("REF-" + Date.now());

  const communicationOutput = {
    email: {
      subject: vars.cdaEmailSubject,
      body: vars.cdaEmailBody
    },
    pdf_letter: {
      title: vars.cdaLetterTitle,
      opening: vars.cdaLetterOpening,
      reasons: vars.cdaLetterReasons,
      next_steps: vars.cdaLetterNextSteps,
      disclosures_notice: vars.cdaLetterDisclosuresNotice
    },
    notification_channel: vars.cdaNotificationChannel,
    required_attachments: vars.cdaRequiredAttachments,
    communication_priority: vars.cdaCommunicationPriority,
    drafted_reasoning: vars.cdaDraftedReasoning,
    drafted_at: new Date().toISOString()
  };

  return {
    ...vars.decisionEvent,
    reference_number: referenceNumber,
    communication_output: communicationOutput
  };]]></bpmn:script>
