    <bpmn:scriptTask id="Activity_caXvIn" name="Loan Application Intake Agent" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse3" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error5" />
          <uipath:output name="decisionEvent" type="jsonSchema" source="" var="decisionEvent" custom="true" target=""><![CDATA[=js:vars.scriptResponse3]]></uipath:output>
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>edge_zQP7pc</bpmn:incoming>
      <bpmn:outgoing>edge_gSeLYX</bpmn:outgoing>
      <bpmn:script><![CDATA[const p = vars.payload;
    const issues = [];

    const required = ['ApplicantName', 'DateOfBirth', 'LastFourSSN', 'RequestedAmount',
                      'LoanPurpose', 'EmployerName', 'AnnualIncome', 'CreditScore',
                      'PortalCreditScoreAge_Days', 'Email'];
    required.forEach(f => {
      if (p[f] === undefined || p[f] === null || p[f] === '') issues.push(`missing_${f}`);
    });

    const dob = new Date(p.DateOfBirth);
    const today = new Date();
    let age = today.getFullYear() - dob.getFullYear();
    const m = today.getMonth() - dob.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
    if (age < 18) issues.push('underage_applicant');

    const lti = p.AnnualIncome > 0 ? p.RequestedAmount / p.AnnualIncome : null;

    const apr = 0.08;
    const months = 60;
    const monthlyRate = apr / 12;
    const estimatedMonthlyPayment =
      (p.RequestedAmount * monthlyRate) / (1 - Math.pow(1 + monthlyRate, -months));

    const monthlyIncome = p.AnnualIncome / 12;
    const pti = monthlyIncome > 0 ? estimatedMonthlyPayment / monthlyIncome : null;

    const creditScoreFreshness = p.PortalCreditScoreAge_Days <= 30 ? 'fresh' : 'stale';

    const intakeOutput = {
      applicant_name: p.ApplicantName,
      applicant_age: age,
      last_four_ssn: p.LastFourSSN,
      employer_name: p.EmployerName,
      loan_purpose: p.LoanPurpose,
      email: p.Email,
      requested_amount: p.RequestedAmount,
      annual_income: p.AnnualIncome,
      credit_score: p.CreditScore,
      credit_score_age_days: p.PortalCreditScoreAge_Days,
      credit_score_freshness: creditScoreFreshness,
      loan_to_income_ratio: Math.round(lti * 10000) / 10000,
      estimated_monthly_payment: Math.round(estimatedMonthlyPayment * 100) / 100,
      payment_to_income_ratio: Math.round(pti * 10000) / 10000,
      intake_status: issues.length > 0 ? 'flagged' : 'clean',
      data_quality_issues: issues,
      intake_completed_at: new Date().toISOString()
    };

    return {
      ...vars.decisionEvent,
      intake_output: intakeOutput
    };]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_tKIAf0" name="Credit Decisioning Agent" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse4" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error6" />
          <uipath:output name="decisionEvent" type="jsonSchema" source="" var="decisionEvent" custom="true" target=""><![CDATA[=js:vars.scriptResponse4]]></uipath:output>
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>edge_gSeLYX</bpmn:incoming>
      <bpmn:outgoing>edge_KgXUNm</bpmn:outgoing>
      <bpmn:script><![CDATA[const intake = vars.decisionEvent.intake_output;

  const reasons = [];
  let thresholds_applied = {};
  let decision_type = "manual_review";
  let risk_level = "medium";

  // Auto-decline: severe credit risk
  if (intake.credit_score < 580) {
    decision_type = "auto_decline";
    risk_level = "high";
    reasons.push(`Credit score ${intake.credit_score} below 580 minimum (Reg B §1002.6 — documented underwriting standard)`);
    thresholds_applied = { credit_score_floor: 580 };
  }
  // Auto-decline: severely over-leveraged
  else if (intake.loan_to_income_ratio > 2.0) {
    decision_type = "auto_decline";
    risk_level = "high";
    reasons.push(`Loan-to-income ratio ${intake.loan_to_income_ratio} exceeds 2.0 ceiling (requested amount more than 2x annual income)`);
    thresholds_applied = { lti_ceiling: 2.0 };
  }
  // Manual review: data quality flagged at intake
  else if (intake.intake_status === "flagged") {
    decision_type = "manual_review";
    risk_level = "medium";
    reasons.push(`Intake flagged with data quality issues: ${intake.data_quality_issues.join(", ")}`);
  }
  // Escalate: high-amount request
  else if (intake.requested_amount > 50000) {
    decision_type = "escalate_senior_review";
    risk_level = "escalated";
    reasons.push(`Requested amount $${intake.requested_amount} exceeds $50,000 senior approval threshold`);
    thresholds_applied = { amount_escalation_floor: 50000 };
  }
  // Escalate: moderately over-leveraged
  else if (intake.loan_to_income_ratio > 1.0) {
    decision_type = "escalate_senior_review";
    risk_level = "escalated";
    reasons.push(`Loan-to-income ratio ${intake.loan_to_income_ratio} exceeds 1.0 (requesting more than annual income)`);
    thresholds_applied = { lti_escalation_threshold: 1.0 };
  }
  // Escalate: high payment burden
  else if (intake.payment_to_income_ratio > 0.40) {
    decision_type = "escalate_senior_review";
    risk_level = "escalated";
    reasons.push(`Payment-to-income ratio ${intake.payment_to_income_ratio} exceeds 0.40 (excessive monthly burden)`);
    thresholds_applied = { pti_escalation_threshold: 0.40 };
  }
  // Auto-approve: all criteria met
  else if (
    intake.credit_score >= 720 &&
    intake.requested_amount <= 10000 &&
    intake.payment_to_income_ratio <= 0.15 &&
    intake.loan_to_income_ratio <= 0.30 &&
    intake.credit_score_freshness === "fresh"
  ) {
    decision_type = "auto_approve";
    risk_level = "low";
    reasons.push(`Credit score ${intake.credit_score} meets auto-approve floor (>=720)`);
    reasons.push(`Requested amount $${intake.requested_amount} within auto-approve ceiling ($10,000)`);
    reasons.push(`Payment-to-income ratio ${intake.payment_to_income_ratio} within tolerance (<=0.15)`);
    reasons.push(`Loan-to-income ratio ${intake.loan_to_income_ratio} within tolerance (<=0.30)`);
    reasons.push(`Credit score data is fresh (<=30 days)`);
    thresholds_applied = {
      credit_score_floor: 720,
      amount_ceiling: 10000,
      pti_ceiling: 0.15,
      lti_ceiling: 0.30,
      freshness_required: "fresh"
    };
  }
  // Default: manual review
  else {
    decision_type = "manual_review";
    risk_level = "medium";
    reasons.push(`Application meets baseline thresholds but does not qualify for auto-approval`);
    reasons.push(`Credit score: ${intake.credit_score}, amount: $${intake.requested_amount}, LTI: ${intake.loan_to_income_ratio}, PTI: ${intake.payment_to_income_ratio}`);
  }

  const riskOutput = {
    decision_type: decision_type,
    risk_level: risk_level,
    reasons: reasons,
    thresholds_applied: thresholds_applied,
    sanctions_status: "pending_check",
    fair_lending_review: "no_protected_class_proxies_used",
    applicant_name: intake.applicant_name,
    credit_score_evaluated: intake.credit_score,
    amount_evaluated: intake.requested_amount,
    policy_version: "v1.0-2026Q2",
    decision_completed_at: new Date().toISOString()
  };

  return {
    ...vars.decisionEvent,
    risk_output: riskOutput
  };]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_AJs7v2" name="Claim Submission Intake Agent" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse5" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error7" />
          <uipath:output name="decisionEvent" type="jsonSchema" source="" var="decisionEvent" custom="true" target=""><![CDATA[=vars.scriptResponse5]]></uipath:output>
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>edge_l5iZks</bpmn:incoming>
      <bpmn:outgoing>edge_uoTGyw</bpmn:outgoing>
      <bpmn:script><![CDATA[const p = vars.payload;
    const issues = [];

    const required = ['MemberID', 'MemberName', 'PolicyNumber', 'ClaimAmount', 'DateOfIncident',
                      'CoverageType', 'ProviderName', 'ClaimType', 'ClaimDescription', 'Email'];
    required.forEach(f => {
      if (p[f] === undefined || p[f] === null || p[f] === '') issues.push(`missing_${f}`);
    });

    const incidentDate = new Date(p.DateOfIncident);
    const today = new Date();
    const daysSinceIncident = Math.floor((today - incidentDate) / (1000 * 60 * 60 * 24));

    if (daysSinceIncident < 0) issues.push('future_dated_incident');

    let timely_filing_status;
    if (daysSinceIncident < 0) timely_filing_status = 'invalid_future_date';
    else if (daysSinceIncident <= 90) timely_filing_status = 'within_window';
    else if (daysSinceIncident <= 365) timely_filing_status = 'late';
    else timely_filing_status = 'severely_late';

    const descriptionWordCount = (p.ClaimDescription || '').trim().split(/\s+/).filter(w => w.length > 0).length;
    if (descriptionWordCount < 5) issues.push('insufficient_description');

    let claim_amount_tier;
    if (p.ClaimAmount < 1000) claim_amount_tier = 'small';
    else if (p.ClaimAmount < 10000) claim_amount_tier = 'medium';
    else if (p.ClaimAmount < 50000) claim_amount_tier = 'large';
    else claim_amount_tier = 'very_large';

    const intakeOutput = {
      member_id: p.MemberID,
      member_name: p.MemberName,
      policy_number: p.PolicyNumber,
      provider_name: p.ProviderName,
      claim_amount: p.ClaimAmount,
      claim_type: p.ClaimType,
      coverage_type: p.CoverageType,
      date_of_incident: p.DateOfIncident,
      claim_description: p.ClaimDescription,
      email: p.Email,
      days_since_incident: daysSinceIncident,
      timely_filing_status: timely_filing_status,
      description_word_count: descriptionWordCount,
      claim_amount_tier: claim_amount_tier,
      intake_status: issues.length > 0 ? 'flagged' : 'clean',
      data_quality_issues: issues,
      intake_completed_at: new Date().toISOString()
    };

    return {
      ...vars.decisionEvent,
      intake_output: intakeOutput
    };]]></bpmn:script>
    </bpmn:scriptTask>
